{
    "name": "curlit",
    "version": "2.0.4",
    "description": "Stop documenting your API manually. cUrlit is an Express middleware that intercepts every request and generates a ready-to-run cURL command — complete with a live browser dashboard. Copy, replay, and export your entire API as a Postman collection in one click.",
    "main": "index.js",
    "exports": "./index.js",
    "bin": {
        "curlit-proxy": "src/proxy/cli.js"
    },
    "type": "module",
    "files": [
        "index.js",
        "src/index.js",
        "src/defaults.js",
        "src/helpers.js",
        "src/ring-buffer.js",
        "src/dashboard/dashboard.js",
        "src/dashboard/dashboard.html",
        "src/proxy/proxy.js",
        "src/proxy/cli.js",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "lint": "npx standard --fix"
    },
    "standard": {
        "ignore": [
            "**/.trash/*"
        ]
    },
    "dependencies": {
        "express": "^4.18.0",
        "http-proxy-middleware": "^3.0.0"
    },
    "keywords": [
        "express",
        "middleware",
        "curl",
        "curlit",
        "logging",
        "debug",
        "postman",
        "dashboard",
        "proxy",
        "php",
        "laravel",
        "django",
        "rails",
        "kotlin",
        "spring"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/daggieblanqx/curlit.git"
    },
    "bugs": {
        "url": "https://github.com/daggieblanqx/curlit/issues"
    },
    "homepage": "https://github.com/daggieblanqx/curlit#readme",
    "author": {
        "name": "Daggie Blanqx",
        "url": "https://github.com/daggieblanqx"
    },
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    }
}
