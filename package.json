{
    "name": "curlit",
    "version": "2.0.2",
    "description": "Stop documenting your API manually. cUrlit is an Express middleware that intercepts every request and generates a ready-to-run cURL command — complete with a live browser dashboard. Copy, replay, and export your entire API as a Postman collection in one click.",
    "main": "index.js",
    "exports": "./index.js",
    "type": "module",
    "files": [
        "index.js",
        "defaults.js",
        "helpers.js",
        "ring-buffer.js",
        "dashboard.js",
        "dashboard.html",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "lint": "npx standard --fix"
    },
    "standard": {
        "ignore": [
            "**/.trash/*"
        ]
    },
    "keywords": [
        "express",
        "middleware",
        "curl",
        "curlit",
        "logging",
        "debug",
        "postman",
        "dashboard"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/daggieblanqx/curlit.git"
    },
    "bugs": {
        "url": "https://github.com/daggieblanqx/curlit/issues"
    },
    "homepage": "https://github.com/daggieblanqx/curlit#readme",
    "author": {
        "name": "Daggie Blanqx",
        "url": "https://github.com/daggieblanqx"
    },
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    }
}